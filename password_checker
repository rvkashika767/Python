# checking the weak passwords for their GitHub or LinkedIn profiles
def passwd_gl(password):
    score_val1 = 0
    comment_dis_val1 = []
    
    # 1. Check length (Inside function)
    if len(password) >= 12:
        score_val1 += 2
    elif len(password) >= 8:
        score_val1 += 1
    else:
        comment_dis_val1.append("Length should be at least 8 char long")

    upper_case = False
    lower_case = False
    digit_case = False
    spl_case = False
    special_chars = "!@#$%,.?\":{}|<>"

    # 2. Check character types
    for char in password:
        if char.isupper(): 
            upper_case = True
        elif char.islower(): 
            lower_case = True
        elif char.isdigit(): 
            digit_case = True
        elif char in special_chars: 
            spl_case = True

    # 3. Final Scoring (OUTSIDE the for loop, but INSIDE the function)
    if upper_case and lower_case: 
        score_val1 += 1
    else: 
        comment_dis_val1.append("It should be a mixture of upper and lower case")
    
    if digit_case: 
        score_val1 += 1
    else: 
        comment_dis_val1.append("Min one Numerical should be present")
    
    if spl_case: 
        score_val1 += 1
    else: 
        comment_dis_val1.append("Min one special character should be present")

    return score_val1, comment_dis_val1

def main():
    # Everything inside main must be indented
    print("="*25)
    print(" Digital Identity check ")
    print("="*25)
    
    user_input = input("Enter a password to test your identity: ")
    strength_score_val1, suggestions = passwd_gl(user_input)
    
    print("\n--- Security Audit Results ---")
    
    if strength_score_val1 >= 5:
        print("Status: Strong Identity")
    elif strength_score_val1 >= 3:
        print("Status: Needs Improvement")
    else:
        print("Status: High Risk of Cybercrime")

    if suggestions:
        print("\nRecommendations to Increase Complexity:")
        for note in suggestions:
            print(f"- {note}")

# Standard Python entry point
if __name__ == "__main__":
    main()
